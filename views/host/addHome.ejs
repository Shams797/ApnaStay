  <%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
      <h2 class="text-2xl font-bold mb-6 text-gray-800"><%= editing ? "Edit" : "Register"%> your home Airbnb</h2>
      <form action="/host/<%= editing ? "edit-home" : "contact-us" %>" method="POST" enctype="multipart/form-data" class="bg-white shadow-md rounded px-8 pt-6 pb-8 w-full max-w-md">
        <input type="hidden" name="id" value="<%= editing ? home._id:''%>" />

        <input type="text" name="housename" placeholder="Enter your house name" required value="<%= editing?home.housename:""%>" class="mb-4 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

        <input type="text" name="price" required value="<%= editing?home.price:""%>" placeholder="Price per night" class="mb-4 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

        <input type="text" name="location" required value="<%= editing?home.location:""%>" placeholder="Location" class="mb-4 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

        <input type="text" name="rating" required value="<%= editing?home.rating:""%>" placeholder="Rating" class="mb-4 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

        <input type="file" name="photo" accept="image/jpg, image/jpeg, image/png" class="mb-6 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

        <input type="text" name="review" value="<%= editing?home.review:""%>" placeholder="Enter your review" class="mb-6 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400" />

      <textarea 
        name="description" 
        placeholder="Describe your home" 
        class="mb-6 w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-400"><%= editing ? home.description : "" %></textarea>

        <input type="submit" value="<%= editing?"update" :"Submit" %>" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded cursor-pointer transition duration-200" />
      </form>
    </main>  
  </body>
</html>