<nav class="bg-gray-800">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <ul class="flex items-center gap-4">
        <li>
          <a
            href="/"
            class="<%= currentPage == 'ApnaStay' ? 'bg-red-600 text-black' : 'text-white hover:bg-red-800' %> bg-red-600 px-4 py-2 rounded-lg text-white font-semibold transition "
          >
            ApnaStay
          </a>
        </li>

        <% if (isLoggedIn) { %>
          <% if (user && user.userType === 'guest') { %>
            <li>
              <a
                href="/homeList"
                class="<%= currentPage == 'homeList' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
              >
                Home List
              </a>
            </li>
            <li>
              <a
                href="/bookings"
                class="<%= currentPage == 'bookings' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
              >
                Bookings
              </a>
            </li>
            <li>
              <a
                href="/favourite"
                class="<%= currentPage == 'favourite' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
              >
                Favourite
              </a>
            </li>
          <% } else { %>
            <li>
              <a
                href="/host/host-home"
                class="<%= currentPage == 'hostHome' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
              >
                Host Home
              </a>
            </li>
            <li>
              <a
                href="/host/contact-us"
                class="<%= currentPage == 'add-home' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition <%= currentPage == 'homeList' ? 'hidden' : '' %>"
              >
                Add Home
              </a>
            </li>
          <% } %>
        <% } %>
      </ul>

      <ul class="flex items-center gap-4">
        <% if(!isLoggedIn){ %>
          <li>
            <a
              href="/login"
              class="<%= currentPage == 'login' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
            >
              LogIn
            </a>
          </li>
          <li>
            <a
              href="/signup"
              class="<%= currentPage == 'signup' ? 'bg-gray-400 text-black' : 'text-white hover:bg-gray-600' %> px-4 py-2 rounded-lg font-semibold transition"
            >
              SignUp
            </a>
          </li>
        <% } else { %>
          <li>
            <form action="/logout" method="POST">
              <button
                type="submit"
                class="text-white hover:bg-gray-600 rounded-lg px-4 py-2 font-semibold transition cursor-pointer"
              >
                LogOut
              </button>
            </form>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

