



<form action="/favourites" method="POST" class="flex-1">
  
  <input 
    type="hidden" 
    name="id" 
    value="<%= home._id %>" 
  />

  <button
    type="submit"
    class="w-full flex items-center justify-center gap-2 bg-red-500 hover:bg-red-600 text-white font-medium px-4 py-2.5 rounded-xl shadow-md hover:shadow-lg transition-all duration-300 hover:scale-105"
  >
    ❤️ Add to Favourite
  </button>

</form>