<%- include('../partials/head') %>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav') %>

  <main class="flex items-center justify-center min-h-[calc(100vh-80px)] py-12 px-4">
    <div class="max-w-md w-full">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Create an Account</h1>
        <p class="mt-2 text-gray-600">Join us and find your perfect home away from home</p>
      </div>

      <!-- Form Card -->
      <div class="bg-white rounded-2xl shadow-xl p-8">
        <form action="/signup" method="post" class="space-y-5">
          
          <!-- error check -->
          <%- include('../partials/errors') %>

          <!-- Name Fields -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="FirstName" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
              <input type="text" name="FirstName" value="<%= oldInput.FirstName ? oldInput.FirstName : '' %>" placeholder="First name" required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition"/>
            </div>
            <div>
              <label for="LastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
              <input type="text" name="LastName" value="<%= oldInput.LastName? oldInput.LastName:'' %>" placeholder="Last name" required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition"/>
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
            <input type="email" name="email" value="<%= oldInput.email? oldInput.email:'' %>" placeholder="you@example.com" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition"/>
          </div>

          <!-- Password -->
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
            <input type="password" name="password" placeholder="Create a password" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition"/>
          </div>

          <!-- Confirm Password -->
          <div>
            <label for="confirm password" class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
            <input type="password" name="confirmPassword" placeholder="Confirm your password" required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-pink-500 outline-none transition"/>
          </div>

          <!-- User Type -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">I am a</label>
            <div class="flex gap-4">
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="userType" value="guest" required class="peer sr-only" <%= oldInput.userType === "guest" ? "checked" : "" %>/>
                <div class="px-4 py-3 border-2 border-gray-200 rounded-lg text-center peer-checked:border-pink-500 peer-checked:bg-pink-50 transition">
                  <span class="text-2xl">🏠</span>
                  <p class="mt-1 font-medium text-gray-700">Guest</p>
                </div>
              </label>
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="userType" value="Host" required class="peer sr-only" <%= oldInput.userType === "Host" ? "checked" : "" %>/>
                <div class="px-4 py-3 border-2 border-gray-200 rounded-lg text-center peer-checked:border-pink-500 peer-checked:bg-pink-50 transition">
                  <span class="text-2xl">🔑</span>
                  <p class="mt-1 font-medium text-gray-700">Host</p>
                </div>
              </label>
            </div>
          </div>

          <!-- Terms Checkbox -->
          <div class="flex items-start gap-3">
            <input type="checkbox" name="term" id="term" required
              class="mt-1 w-5 h-5 text-pink-500 border-gray-300 rounded focus:ring-pink-500"/>
            <label for="term" class="text-sm text-gray-600" >
              I agree to the <a href="#" class="text-pink-500 hover:underline">Terms of Service</a> and <a href="#" class="text-pink-500 hover:underline">Privacy Policy</a>
            </label>
          </div>

          <!-- Submit Button -->
          <button type="submit" value="Register"
            class="w-full bg-pink-500 hover:bg-pink-600 text-white font-semibold py-3 px-4 rounded-lg transition transform hover:scale-[1.02] active:scale-[0.98]">
            Create Account
          </button>
        </form>

        <!-- Login Link -->
        <p class="mt-6 text-center text-gray-600">
          Already have an account?
          <a href="/login" class="text-pink-500 hover:text-pink-600 font-medium hover:underline">Login</a>
        </p>
      </div>
    </div>
  </main>
</body>
</html>